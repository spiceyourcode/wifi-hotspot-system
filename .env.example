# ============================================================
#  HOTSPOT MONETIZATION SYSTEM — ENVIRONMENT CONFIGURATION
# ============================================================

# --- Server ---
PORT=3000
NODE_ENV=production
BASE_URL=https://your-domain.com          # or ngrok URL in dev

# --- M-Pesa Daraja API ---
MPESA_CONSUMER_KEY=your_consumer_key_here
MPESA_CONSUMER_SECRET=your_consumer_secret_here
MPESA_SHORTCODE=174379                    # Lipa Na M-Pesa shortcode (Paybill or Till)
MPESA_PASSKEY=your_passkey_here
MPESA_CALLBACK_URL=https://your-domain.com/callback/mpesa
MPESA_ENV=sandbox                         # sandbox | production

# --- MySQL Database ---
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=hotspot_user
DB_PASSWORD=StrongPassword123!
DB_NAME=hotspot_db
DB_POOL_SIZE=10

# --- MikroTik Router ---
MIKROTIK_HOST=192.168.88.1
MIKROTIK_PORT=8728
MIKROTIK_USER=admin
MIKROTIK_PASSWORD=your_mikrotik_password
MIKROTIK_HOTSPOT_SERVER=hotspot1         # Name of your hotspot server in RouterOS

# --- Security ---
RATE_LIMIT_WINDOW_MS=60000               # 1 minute
RATE_LIMIT_MAX_REQUESTS=20
CALLBACK_SECRET=random_secret_for_validation

# --- Trial Config (informational — actual config is on MikroTik) ---
TRIAL_PROFILE=trial
TRIAL_DURATION_MINUTES=3
